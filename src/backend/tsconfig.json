{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "lib": ["ES2022"],
        "outDir": "./dist",
        "rootDir": "../",
        "strict": true,
        "strictFunctionTypes": false,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "moduleResolution": "node",
    },
    "include": [
        "src/**/*",
        "../shared/**/*"
    ],
    "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
